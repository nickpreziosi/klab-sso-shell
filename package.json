{
  "name": "klab-sso-shell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:all": "concurrently --names \"SHELL,KRISK,KBPM,KLEADS\" --prefix-colors \"blue,cyan,green,magenta\" \"next dev --hostname 127.0.0.1\" \"npm --prefix ../ux-krisk run dev\" \"npm --prefix ../keo-core-admin-web-ui run dev\" \"npm --prefix ../klab-gbl-kleads-portal-web-ui run dev\"",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mobile:sync": "cap sync",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "mobile:dev:android": "cap run android --livereload --external",
    "mobile:dev:ios": "cap run ios --livereload --external"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@k-lab/components": "^0.8.0",
    "firebase": "^12.12.1",
    "lucide-react": "^0.553.0",
    "next": "^16.1.6",
    "next-intl": "^4.13.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
