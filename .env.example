# Firebase web config (client SDK). Copy to .env.local and fill in.
# These power the shell's authentication (login / session / logout).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# No per-app env vars are needed for dev proxies.
# App ports and URLs are configured centrally in config/apps/proxy-config.ts.

# ── Capacitor / Mobile ────────────────────────────────────────────────────────
# Set this to your deployed Next.js URL before running `npx cap sync`.
# Leave empty during local dev — use `npm run mobile:dev:android` (live-reload) instead.
CAPACITOR_SERVER_URL=

# Set to "false" before building a release for the Play Store / App Store.
# Defaults to true (enabled) to allow Chrome DevTools inspection during development.
CAPACITOR_DEBUG=true

# Only set to "true" if your dev server runs on plain HTTP (not HTTPS). Never use in production.
CAPACITOR_ALLOW_CLEARTEXT=false
