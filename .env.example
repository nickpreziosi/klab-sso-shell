# Firebase web config (client SDK). Copy to .env.local and fill in.
# These power the shell's authentication (login / session / logout).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Dev-only: proxy ux-krisk into /krisk (run ux-krisk on port 3001).
KRISK_DEV_ORIGIN=http://127.0.0.1:3001
