# Firebase web config (client SDK). Copy to .env.local and fill in.
# These power the shell's authentication (login / session / logout).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cross-subdomain SSO (platform profile)
# Shell sets KLabPlatformPresence + KLabPlatformToken on this domain at login.
# Dev uses *.lvh.me (public wildcard DNS → 127.0.0.1, no /etc/hosts needed):
# *.localhost cannot share cookies because `localhost` is a single-label
# domain (treated like a TLD).
NEXT_PUBLIC_DEPLOYMENT_PROFILE=platform
NEXT_PUBLIC_COOKIE_DOMAIN=.lvh.me
NEXT_PUBLIC_SHELL_ORIGIN=http://app.lvh.me:3000

# Production overrides (deploy config, not committed):
# NEXT_PUBLIC_COOKIE_DOMAIN=.k-lab.ai
# NEXT_PUBLIC_SHELL_ORIGIN=https://app.k-lab.ai
# Cookies use Secure=true automatically when NODE_ENV=production.
# Firebase Console → Authentication → Authorized domains: app.k-lab.ai, krisk.k-lab.ai, kbpm.k-lab.ai, kleads.k-lab.ai

# Optional: Firebase Admin for custom-token handoff (same project as client SDK)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Platform layout: subdomain-native (default) | iframe-embed (legacy dev proxy + iframes)
# NEXT_PUBLIC_PLATFORM_LAYOUT=subdomain-native

# Subdomain-native local dev (see config/platform/dev-hosts.ts):
#   Shell: http://app.lvh.me:3000
#   K Risk: http://krisk.lvh.me:3001  |  KBPM: http://kbpm.lvh.me:3002  |  K Leads: http://kleads.lvh.me:3003
# Run all four: npm run dev:all
